{
  "name": "ccn",
  "displayName": "CCN — Claude/Codex Notifier",
  "description": "Claude Code, Codex 등 사이드바 AI 에이전트의 작업 완료/입력 대기를 VSCode 안에서 알려주는 확장",
  "version": "0.0.1",
  "publisher": "fb-pd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/youpd/CCN.git"
  },
  "bugs": {
    "url": "https://github.com/youpd/CCN/issues"
  },
  "homepage": "https://github.com/youpd/CCN#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Notebooks"],
  "keywords": ["claude", "claude-code", "codex", "openai", "notifications", "hooks", "productivity"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccn.test",
        "title": "CCN: Send Test Notification",
        "category": "CCN"
      },
      {
        "command": "ccn.installClaudeHooks",
        "title": "CCN: Install Claude Code Hooks",
        "category": "CCN"
      },
      {
        "command": "ccn.uninstallClaudeHooks",
        "title": "CCN: Uninstall Claude Code Hooks",
        "category": "CCN"
      },
      {
        "command": "ccn.installCodexHook",
        "title": "CCN: Install Codex Hook",
        "category": "CCN"
      },
      {
        "command": "ccn.uninstallCodexHook",
        "title": "CCN: Uninstall Codex Hook",
        "category": "CCN"
      },
      {
        "command": "ccn.history.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ccn.history.clear",
        "title": "Clear History",
        "icon": "$(clear-all)"
      },
      {
        "command": "ccn.history.muteToggle",
        "title": "Toggle Mute",
        "icon": "$(bell-slash)"
      },
      {
        "command": "ccn.showOutput",
        "title": "CCN: Show Output Log",
        "category": "CCN"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccn-sidebar",
          "title": "CCN",
          "icon": "$(bell)"
        }
      ]
    },
    "views": {
      "ccn-sidebar": [
        {
          "id": "ccn.history",
          "name": "Notifications",
          "icon": "$(bell)",
          "contextualTitle": "CCN"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "ccn.history.muteToggle", "when": "view == ccn.history", "group": "navigation@1" },
        { "command": "ccn.history.refresh", "when": "view == ccn.history", "group": "navigation@2" },
        { "command": "ccn.history.clear", "when": "view == ccn.history", "group": "navigation@3" }
      ]
    },
    "configuration": {
      "title": "CCN",
      "properties": {
        "ccn.claude.notifyOnPermissionRequest": {
          "type": "boolean", "default": true,
          "description": "Claude가 권한을 요청할 때 알림"
        },
        "ccn.claude.notifyOnQuestion": {
          "type": "boolean", "default": true,
          "description": "Claude가 질문할 때(elicitation) 알림"
        },
        "ccn.claude.notifyOnTaskComplete": {
          "type": "boolean", "default": true,
          "description": "Claude가 작업을 마치고 idle 상태가 될 때 알림 (Stop hook)"
        },
        "ccn.claude.notifyOnSubagentStop": {
          "type": "boolean", "default": false,
          "description": "Claude 서브에이전트 종료 시 알림"
        },
        "ccn.claude.notifyOnDangerousTool": {
          "type": "boolean", "default": false,
          "description": "위험 도구(Bash/Write/Edit 등) 호출 직전 알림. Notification hook이 권한 모달에서 fire 안 될 때 fallback. 변경 시 hook 자동 재설치됨. 도구 호출마다 fire되므로 노이즈에 주의."
        },
        "ccn.claude.dangerousToolMatcher": {
          "type": "string", "default": "Bash|Write|Edit",
          "description": "위험 도구 알림 matcher (정규식). notifyOnDangerousTool이 true일 때만 사용."
        },
        "ccn.codex.notifyOnTaskComplete": {
          "type": "boolean", "default": true,
          "description": "Codex 작업 완료 시 알림 (Codex hook이 설치되어 있어야 함)"
        },
        "ccn.systemNotification": {
          "type": "boolean", "default": true,
          "description": "VSCode 알림과 함께 OS 토스트 표시"
        },
        "ccn.sound": {
          "type": "boolean", "default": true,
          "description": "알림 사운드 재생"
        },
        "ccn.notificationDelayMs": {
          "type": "number", "default": 0, "minimum": 0, "maximum": 60000,
          "description": "VSCode 팝업을 이 시간 안에 dismiss하면 OS 토스트/사운드 취소 (ms)"
        },
        "ccn.suppressWhenFocused": {
          "type": "boolean", "default": false,
          "description": "VSCode가 활성 창일 때 OS 토스트/사운드 생략 (인앱 메시지는 유지)"
        },
        "ccn.mute": {
          "type": "boolean", "default": false,
          "description": "모든 알림 일시 정지 (사이드바 토글로 변경 가능)"
        },
        "ccn.history.maxItems": {
          "type": "number", "default": 200, "minimum": 10, "maximum": 5000,
          "description": "사이드바 히스토리 최대 보관 개수"
        },
        "ccn.webhook.telegram.botToken": {
          "type": "string", "default": "",
          "description": "Telegram Bot Token (BotFather에서 발급). 비어 있으면 비활성"
        },
        "ccn.webhook.telegram.chatId": {
          "type": "string", "default": "",
          "description": "Telegram Chat ID (메시지 받을 대상)"
        },
        "ccn.webhook.telegram.onlyWhenUnfocused": {
          "type": "boolean", "default": true,
          "description": "VSCode가 비활성일 때만 Telegram 전송"
        }
      }
    }
  },
  "scripts": {
    "test": "node test/run.js"
  },
  "devDependencies": {}
}
